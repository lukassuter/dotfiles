[
  {
    "command": "workbench.view.scm",
    "key": "cmd+shift+g",
    "when": "workbench.scm.active",
  },
  {
    "command": "editor.action.jumpToBracket",
    "key": "cmd+e",
    "when": "editorTextFocus",
  },
  {
    "key": "cmd+shift+n",
    "command": "extension.advancedNewFile",
  },
  {
    "key": "alt+cmd+j",
    "command": "merge-conflict.next",
  },
  {
    "key": "alt+cmd+h",
    "command": "merge-conflict.previous",
  },
  {
    "key": "f11",
    "command": "-extension.node-debug.startWithStopOnEntry",
    "when": "!inDebugMode && activeViewlet == 'workbench.view.debug' && debugConfigurationType == 'node' || !inDebugMode && activeViewlet == 'workbench.view.debug' && debugConfigurationType == 'pwa-extensionHost' || !inDebugMode && activeViewlet == 'workbench.view.debug' && debugConfigurationType == 'pwa-node'",
  },
  {
    "key": "cmd+7",
    "command": "editor.action.commentLine",
    "when": "editorTextFocus && !editorReadonly",
  },
  {
    "key": "shift+cmd+7",
    "command": "-editor.action.commentLine",
    "when": "editorTextFocus && !editorReadonly",
  },
  {
    "key": "shift+cmd+r",
    "command": "-rerunSearchEditorSearch",
    "when": "inSearchEditor",
  },
  {
    "key": "shift+cmd+y",
    "command": "-workbench.debug.action.toggleRepl",
    "when": "workbench.panel.repl.view.active",
  },
  {
    "key": "shift+cmd+[Comma] cmd+o",
    "command": "-testing.showMostRecentOutput",
    "when": "testing.hasAnyResults",
  },
  {
    "key": "shift+cmd+r",
    "command": "workbench.view.extension.test",
  },
  {
    "key": "shift+cmd+t",
    "command": "-mergeEditor.toggleBetweenInputs",
    "when": "isMergeEditor",
  },
  {
    "key": "shift+cmd+t",
    "command": "-workbench.action.reopenClosedEditor",
  },
  {
    "key": "shift+cmd+y",
    "command": "editor.action.goToTypeDefinition",
  },
  {
    "key": "shift+cmd+y",
    "command": "-chatEditor.action.accept",
    "when": "chatEdits.hasEditorModifications && chatEdits.isGlobalEditingSession && editorFocus && !chatEdits.isCurrentlyBeingModified || chatEdits.hasEditorModifications && chatEdits.isGlobalEditingSession && notebookEditorFocused && !chatEdits.isCurrentlyBeingModified",
  },
  {
    "key": "shift+cmd+t",
    "command": "workbench.action.reopenClosedEditor",
  },
  {
    "key": "cmd+b",
    "command": "-workbench.action.toggleSidebarVisibility",
  },
  {
    "key": "cmd+b",
    "command": "workbench.action.togglePanel",
  },
  {
    "key": "cmd+j",
    "command": "-workbench.action.togglePanel",
  },
  {
    "key": "cmd+g",
    "command": "-editor.action.nextMatchFindAction",
    "when": "editorFocus",
  },
  {
    "key": "cmd+g",
    "command": "-workbench.action.terminal.findNext",
    "when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported",
  },
  {
    "key": "cmd+g",
    "command": "-workbench.action.terminal.goToRecentDirectory",
    "when": "terminalFocus && terminalHasBeenCreated || terminalFocus && terminalProcessSupported",
  },
  {
    "key": "cmd+g",
    "command": "-notebook.findNext.fromWidget",
    "when": "findWidgetVisible && notebookEditorFocused",
  },
  {
    "key": "cmd+g",
    "command": "-workbench.action.browser.findNext",
    "when": "browserFindWidgetVisible && activeEditor == 'workbench.editor.browser'",
  },
  {
    "key": "cmd+g",
    "command": "workbench.action.toggleSidebarVisibility",
  },
  {
    "key": "cmd+h",
    "command": "workbench.action.toggleAuxiliaryBar",
  },
  {
    "key": "alt+cmd+b",
    "command": "-workbench.action.toggleAuxiliaryBar",
  },
]
